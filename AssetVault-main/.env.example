# Google Apps Script Web App URL (Deploy > New deployment > Web app)
GAS_WEBAPP_URL=
# Session signing key — min 32 random characters (openssl rand -base64 32)
SESSION_SECRET=
# New spreadsheet (2026): https://docs.google.com/spreadsheets/d/1AZJTjLCviNobGM2f4-6ekDZyVW09XS0jIN4xPvzR2Tk/edit
SPREADSHEET_ID=
# Users tab gid — after setupSheets, open Users tab and copy gid from URL
USERS_SHEET_GID=
# Server-side only — do NOT expose via Vite client bundle
GEMINI_API_KEY=
APP_URL=
APP_BASE_URL=
FRONTEND_URL=
NETLIFY_URL=
SMTP_EMAIL=
SMTP_PASSWORD=
SMTP_HOST=
SMTP_PORT=
OTP_FROM_EMAIL=
OTP_USE_SMTP=
